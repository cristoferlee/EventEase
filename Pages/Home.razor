@page "/"

<PageTitle>Home</PageTitle>

<h1>Welcome to EventEase</h1>

<p>Discover and register for upcoming events in your area.</p>

<h2>Featured Events</h2>

<div class="row">
    @foreach (var evt in events)
    {
        <div class="col-md-4 mb-3" @key="evt.Id">
            <EventCard Name="@evt.Name" Date="@evt.Date" Location="@evt.Location" />
        </div>
    }
</div>

<div class="mt-4">
    <NavLink href="/events" class="btn btn-primary me-2">View All Events</NavLink>
    <NavLink href="/register" class="btn btn-secondary">Register for Events</NavLink>
</div>

@code {
    private List<EventModel> events = new()
    {
        new() { Id = 1, Name = "Tech Conference", Date = new DateTime(2026, 5, 15, 10, 0, 0), Location = "Convention Center" },
        new() { Id = 2, Name = "Music Festival", Date = new DateTime(2026, 6, 20, 18, 0, 0), Location = "Central Park" },
        new() { Id = 3, Name = "Art Exhibition", Date = new DateTime(2026, 7, 10, 14, 0, 0), Location = "Art Gallery" }
    };

    public class EventModel
    {
        public int Id { get; set; }
        public string? Name { get; set; }
        public DateTime Date { get; set; }
        public string? Location { get; set; }
    }
}
